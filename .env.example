# ═══════════════════════════════════════════════════════════════════════════════
# Code-Analyser — Master Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to `.env` and populate with real values.
#   cp .env.example server/.env
#
# All variables have sensible defaults for local development.
# In production, inject via your platform's secret manager (AWS SSM, Vault, etc).
# ═══════════════════════════════════════════════════════════════════════════════


# ─── Infrastructure ───────────────────────────────────────────────────────────
#
# Start Redis, Qdrant & Neo4j with:   docker compose up -d
# All credentials below match the docker-compose.yml defaults out of the box.


# ─── App Config ───────────────────────────────────────────────────────────────

NODE_ENV=development             # "development" | "production"
PORT=3001                        # Express server port


# ─── LLM Providers ───────────────────────────────────────────────────────────
#
# The council agents use a model-agnostic LLM abstraction.  Swap the provider
# by implementing a different `LLMCompletionFn` in src/index.ts.
# The stub LLM works out of the box for pipeline testing (no API key needed).

OPENAI_API_KEY=sk-xxxx           # OpenAI — for GPT-4o / text-embedding-3-small
OPENAI_MODEL=gpt-4o              # Which chat model the council agents use
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

ANTHROPIC_API_KEY=sk-ant-xxxx    # Anthropic — alternative LLM provider
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# If using a local Ollama / vLLM server instead:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1:70b


# ─── Embedding Config ────────────────────────────────────────────────────────

EMBEDDING_DIM=384                # Dimension of embedding vectors (384 for MiniLM, 1536 for OpenAI)


# ─── Qdrant (Vector Database — Phase 3: GraphRAG) ────────────────────────────

QDRANT_URL=http://localhost:6333 # Qdrant REST endpoint
QDRANT_API_KEY=                  # Leave blank for local Docker; set in Qdrant Cloud
QDRANT_COLLECTION=code_chunks    # Default collection name for code embeddings


# ─── Neo4j (Graph Database — Phase 3: GraphRAG) ──────────────────────────────

NEO4J_URI=bolt://localhost:7687  # Bolt protocol URI
NEO4J_USERNAME=neo4j             # Default username
NEO4J_PASSWORD=password          # ⚠️  Change in production!
NEO4J_DATABASE=neo4j             # Database name (default for Community Edition)


# ─── Redis (Queue + Pub/Sub — Phase 5: Delivery) ─────────────────────────────

REDIS_HOST=127.0.0.1             # Redis host
REDIS_PORT=6379                  # Redis port
REDIS_PASSWORD=                  # Leave blank for local; set for Redis Cloud / Sentinel
REDIS_DB=0                       # Redis database index (0–15)


# ─── BullMQ Worker Config ────────────────────────────────────────────────────

ENABLE_WORKER=true               # Start the BullMQ worker in-process (set "false" for separate worker deploy)
WORKER_CONCURRENCY=2             # Max parallel jobs per worker instance
WORKER_RATE_LIMIT=5              # Max jobs started per 60 s window


# ─── LangGraph Council Config ────────────────────────────────────────────────

COUNCIL_MAX_ITERATIONS=10        # Max ReAct loop iterations per agent (circuit breaker)
COUNCIL_MAX_REINVESTIGATIONS=2   # Max re-investigation cycles when critique dispute rate is high
COUNCIL_DISPUTE_THRESHOLD=0.6    # Dispute rate (0.0–1.0) to trigger re-investigation
COUNCIL_TEMPERATURE=0.3          # LLM temperature for council agents (lower = more deterministic)


# ─── Client / Frontend ───────────────────────────────────────────────────────
#
# The Vite dev server proxies /api → http://localhost:$PORT automatically.
# In production, set VITE_API_BASE_URL to the real backend origin.

VITE_API_BASE_URL=               # e.g. https://api.codeanalyser.io (blank = same-origin proxy)
